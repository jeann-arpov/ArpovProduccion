<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Diferencia_de_Cambio__c</fullName>
    <description>Calcula la Diferencia de Cambio entre lo Pagado y la FC Original para un APSE</description>
    <externalId>false</externalId>
    <formula>IF(Documento_Afectado__c &lt;&gt; &quot;&quot;,  Total_Cobranza_SE__c - Importe_Afectado_MN__c, 0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Calcula la Diferencia de Cambio entre lo Pagado y la FC Original para un APSE</inlineHelpText>
    <label>Diferencia de Cambio</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
