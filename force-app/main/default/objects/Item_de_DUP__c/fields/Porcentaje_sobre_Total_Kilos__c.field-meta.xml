<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Porcentaje_sobre_Total_Kilos__c</fullName>
    <description>Participación de la línea en el total de la transaccion</description>
    <formula>IF( Transaccion__r.Kilos_Totales_RE__c &lt;&gt; 0, Kilos_Totales__c / Transaccion__r.Kilos_Totales_RE__c, null)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Porcentaje sobre Total (Kilos)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>8</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
