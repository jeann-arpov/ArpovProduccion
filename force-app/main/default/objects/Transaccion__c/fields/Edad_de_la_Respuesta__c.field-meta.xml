<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Edad_de_la_Respuesta__c</fullName>
    <externalId>false</externalId>
    <formula>IF( 
   AND( NOT( ISPICKVAL( Estado__c, &quot;Cobrada&quot; ) ),
        NOT( ISBLANK( Fecha_de_Respuesta__c ) )
   ),
   ( TODAY() - Fecha_de_Respuesta__c ),
   0
)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Dias en estado Respondida.</inlineHelpText>
    <label>Edad de la Respuesta</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
