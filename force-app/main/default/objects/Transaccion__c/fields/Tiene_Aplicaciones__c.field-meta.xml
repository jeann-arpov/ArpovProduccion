<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Tiene_Aplicaciones__c</fullName>
    <description>Indica si la transaccion DUP o AUD tiene aplicaciones</description>
    <formula>( Tiene_Aplicaciones_DUP__c +  Tiene_Aplicaciones_AUD__c ) &gt; 0</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Tiene Aplicaciones</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
