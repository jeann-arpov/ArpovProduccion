<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Valida_Informado_por_Don_Mario</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
 Informado_por_Don_Mario__c = true,
