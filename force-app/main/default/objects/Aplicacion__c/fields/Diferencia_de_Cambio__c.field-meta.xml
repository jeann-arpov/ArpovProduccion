<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Diferencia_de_Cambio__c</fullName>
    <description>Muestra la diferencia de cambio real  implícita en el pago</description>
    <externalId>false</externalId>
