        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Total_a_Facturar</fullName>
        <description>Calcula el importe total a facturar para este ítem de auditoria en función de otros valores calculados en el ítem.</description>
        <field>Total_a_Facturar__c</field>
        <formula>IF( Conversion__c &lt;&gt; &quot;ARS&quot;,
	((( 
		IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
			Cantidad_Relevada__c * Densidad_de_Siembra__c, 
			IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
				Cantidad_Relevada__c * 1, 
				VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c
				)
			) 
		) / Unidad_de_Medida_de_Facturacion__c) * Precio_Unitario_Producto__c
	)* Tipo_de_Cambio__c,
	(((
		IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
			Cantidad_Relevada__c * Densidad_de_Siembra__c, 
			IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
				Cantidad_Relevada__c * 1, 
				VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
				) 
			) 
		) / Unidad_de_Medida_de_Facturacion__c) * Precio_Unitario_Producto__c 
	)
) +  
( ( IF( Conversion__c &lt;&gt; &quot;ARS&quot;,
	((( 
		IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
			Cantidad_Relevada__c * Densidad_de_Siembra__c, 
			IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
				Cantidad_Relevada__c * 1, 
				VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
				) 
			) 
		) / Unidad_de_Medida_de_Facturacion__c) * Precio_Unitario_Producto__c 
	)* Tipo_de_Cambio__c,
			((( 
				IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
					Cantidad_Relevada__c * Densidad_de_Siembra__c, 
					IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
						Cantidad_Relevada__c * 1, 
						VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
						) 
					) 
				) / Unidad_de_Medida_de_Facturacion__c) * Precio_Unitario_Producto__c 
			)
		) 
	) * VALUE( TEXT( Resarcimiento_Porcentaje__c ) )
) - 
	((( 
		( IF( Conversion__c &lt;&gt; &quot;ARS&quot;,
			(((
				IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;),
					Cantidad_Relevada__c * Densidad_de_Siembra__c, 
					IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
						Cantidad_Relevada__c * 1, 
						VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c
						) 
					) 
				) / Unidad_de_Medida_de_Facturacion__c
			 ) * Precio_Unitario_Producto__c 
			)* Tipo_de_Cambio__c,
			((( 
				IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
					Cantidad_Relevada__c * Densidad_de_Siembra__c, 
					IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
						Cantidad_Relevada__c * 1, 
						VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
						) 
					) 
				) / Unidad_de_Medida_de_Facturacion__c
			 ) * Precio_Unitario_Producto__c 
			)
		   )
		) + Importe_de_Resarcimiento__c 
	   ) * Descuento_Porcentaje__c
	  ) + (IF( Conversion__c &lt;&gt; &quot;ARS&quot;,
				(((
					IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
						Cantidad_Relevada__c * Densidad_de_Siembra__c, 
							IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
								Cantidad_Relevada__c * 1, 
								VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
								) 
							) 
						) / Unidad_de_Medida_de_Facturacion__c
					) * Precio_Unitario_Producto__c 
				)* Tipo_de_Cambio__c,
				(((
					IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Hectáreas&quot;), 
						Cantidad_Relevada__c * Densidad_de_Siembra__c, 
						IF(ISPICKVAL( Unidad_de_Medida_Relevada__c ,&quot;Granel&quot;),
							Cantidad_Relevada__c * 1, 
							VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c 
							) 
						) 
					) / Unidad_de_Medida_de_Facturacion__c
				  ) * Precio_Unitario_Producto__c 
				)
			  )
			) * Descuento_Producto__c  )  +  
IF( ISBLANK( TEXT( Monto_Fijo__c) ), 
	0, 
	VALUE( TEXT( Monto_Fijo__c ) ) 
	)</formula>
        <name>Total a Facturar</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
