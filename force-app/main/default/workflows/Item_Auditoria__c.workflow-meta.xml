    <fieldUpdates>
        <fullName>Kilos_Totales</fullName>
        <description>Calcula los Kilos totales</description>
        <field>Z9_Kilos_Totales__c</field>
        <formula>IF(ISPICKVAL(  Unidad_de_Medida_Relevada__c  ,&quot;Hectáreas&quot;),  Cantidad_Relevada__c * Densidad_de_Siembra__c, 
IF(ISPICKVAL(  Unidad_de_Medida_Relevada__c  ,&quot;Granel&quot;),Cantidad_Relevada__c * 1, VALUE( TEXT(Unidad_de_Medida_Relevada__c) ) * Cantidad_Relevada__c ) )</formula>
        <name>Kilos Totales</name>
        <notifyAssignee>false</notifyAssignee>
