    <rules>
        <fullName>Factura%2E Cobrada por Umbral</fullName>
        <actions>
            <name>Factura_Confirmacion_de_Pago</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Factura_Etapa_Cobrada</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Factura_Saldo_a_Gestionar_cero</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Asigna el estado Cobrada a las facturas con saldo bajo el umbral.</description>
        <formula>AND( Saldo_a_Cobrar_Comprobante__c &gt; 0,  RecordType.DeveloperName = &apos;Regalia_Extendida&apos;,
	OR( 
		AND( 
			OR( ISPICKVAL( Divisa_Comprobante__c, &quot;USD&quot; ), ISPICKVAL( Divisa_Comprobante__c, &quot;EUR&quot; ) ), 
			OR( 
				AND( 
				Total_Comprobante__c &gt; Obtentor__r.Umbral_Importe__c, 
				Saldo_a_Cobrar_Comprobante__c &lt;= Obtentor__r.Umbral_Base__c 
				), 
				AND( 
				Total_Comprobante__c &lt;= Obtentor__r.Umbral_Importe__c, 
				Saldo_a_Cobrar_Comprobante__c &lt;= Total_Comprobante__c * Obtentor__r.Umbral_Porcentaje__c 
				) 
			) 
		), 
		AND( 
			ISPICKVAL( Divisa_Comprobante__c, &quot;ARS&quot; ), 
			OR( 
				AND( 
				( Total_Comprobante__c / nullvalue(Tipo_de_Cambio_Actualizado__c,1) )&gt; Obtentor__r.Umbral_Importe__c, 
				( Saldo_a_Cobrar_Comprobante__c / nullvalue(Tipo_de_Cambio_Actualizado__c,1) ) &lt;= Obtentor__r.Umbral_Base__c 
				), 
				AND( 
				( Total_Comprobante__c / nullvalue(Tipo_de_Cambio_Actualizado__c,1) ) &lt; Obtentor__r.Umbral_Importe__c, 
				( Saldo_a_Cobrar_Comprobante__c / nullvalue(Tipo_de_Cambio_Actualizado__c,1) ) &lt;= Total_Comprobante__c * Obtentor__r.Umbral_Porcentaje__c 
				) 
			) 
		) 
	) 
)</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
