    <fieldUpdates>
        <fullName>NC_Actualiza_Saldo_a_Cobrar</fullName>
        <description>Resta el importe de la NC al Saldo a Cobrar del comprobante</description>
        <field>Saldo_a_Cobrar_Comprobante__c</field>
        <formula>IF( (Saldo_a_Cobrar_Comprobante__c - Importe_a_Aplicar_NC__c) &lt;= 0, 0,
Saldo_a_Cobrar_Comprobante__c - Importe_a_Aplicar_NC__c
)</formula>
        <name>NC. Actualiza Saldo a Cobrar</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>NC_Actualiza_Saldo_a_Gestionar</fullName>
        <description>Actualiza el Saldo a Gestionar restándole el importe de la NC</description>
        <field>Saldo_a_Gestionar__c</field>
        <formula>IF( OR( ISPICKVAL( Divisa_Comprobante__c, &quot;USD&quot; ), ISPICKVAL( Divisa_Comprobante__c, &quot;EUR&quot; ) ), 
IF(Total_Comprobante__c &lt;= Obtentor__r.Umbral_Importe__c, 
IF(PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c &lt;= Total_Comprobante__c * Obtentor__r.Umbral_Porcentaje__c, 
0, 
PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ), 
IF(PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c &lt;= Obtentor__r.Umbral_Base__c, 
0, 
PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ) 
), 
IF( ( Total_Comprobante__c / Tipo_de_Cambio_Actualizado__c ) &lt;= Obtentor__r.Umbral_Importe__c, 
IF( ( PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ) / Tipo_de_Cambio_Actualizado__c &lt;= ( Total_Comprobante__c / Tipo_de_Cambio_Actualizado__c ) * Obtentor__r.Umbral_Porcentaje__c, 
0, 
PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ), 
IF( ( PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ) / Tipo_de_Cambio_Actualizado__c &lt;= Obtentor__r.Umbral_Base__c, 
0, 
PRIORVALUE( Saldo_a_Cobrar_Comprobante__c ) - Importe_a_Aplicar_NC__c ) 
) 
)</formula>
        <name>NC. Actualiza Saldo a Gestionar</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
