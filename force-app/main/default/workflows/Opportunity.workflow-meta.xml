        <formula>IF( Account.Tiempo_de_Pago__c = &quot;&lt;45 dias&quot;,Fecha_Vencimiento_Comprobante__c + 30,
IF( Account.Tiempo_de_Pago__c = &quot;45-90 dias&quot;,Fecha_Vencimiento_Comprobante__c + 40,
IF( Account.Tiempo_de_Pago__c = &quot;90-180 dias&quot;,Fecha_Vencimiento_Comprobante__c + 80,
IF( Account.Tiempo_de_Pago__c = &quot;180 dias-1 año&quot;,Fecha_Vencimiento_Comprobante__c + 170,
IF( Account.Tiempo_de_Pago__c = &quot;&gt;1 año&quot;,Fecha_Vencimiento_Comprobante__c + 350,
Fecha_Vencimiento_Comprobante__c + 30)))))</formula>
