    <rules>
        <fullName>Venta%2E Tipo C</fullName>
        <actions>
            <name>Venta_Tipo_C</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Si el Orginante es un obtentor y el destinario un comercio o distribuidor es una venta del tipo &quot;C&quot;</description>
        <formula>Cargado_desde_Archivo__c = TRUE &amp;&amp; Originante__r.RecordType.Name = &quot;Obtentor&quot; &amp;&amp;(Destinatario__r.RecordType.Name = &quot;Distribuidor&quot; || Destinatario__r.RecordType.Name = &quot;Comercio&quot;)</formula>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Venta%2E Tipo TD</fullName>
        <actions>
            <name>Venta_Tipo_TD</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Si el Originainte y el destinatario son comercio o distribuidor es una venta del tipo &quot;TD&quot;</description>
        <formula>Cargado_desde_Archivo__c = TRUE &amp;&amp; (Originante__r.RecordType.Name = &quot;Distribuidor&quot; || Originante__r.RecordType.Name = &quot;Comercio&quot;) &amp;&amp;(Destinatario__r.RecordType.Name = &quot;Distribuidor&quot; || Destinatario__r.RecordType.Name = &quot;Comercio&quot;)</formula>
