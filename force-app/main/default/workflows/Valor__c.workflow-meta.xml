    <rules>
        <fullName>Cheque - Carga Identificacion</fullName>
        <actions>
            <name>Cheque_Codigo_Postal</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Entidad_Bancaria</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_FlowTrigger_Desact</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Genera_Identificacion</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Numero_Cheque</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Numero_Cuenta</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Sucursal</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Se ejecuta cuando se carga la identificación de un cheque mediante una lectora / scanner de cheques.</description>
        <formula>AND(
 OR(TEXT(Forma_de_Pago__c) = &quot;Cheque&quot;, TEXT(Forma_de_Pago__c) = &quot;Cheque Diferido&quot;),
 LEN( Identificacion__c )  &gt;= 10
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cheque - Genera Identificacion Inicial</fullName>
        <actions>
            <name>Cheque_FlowTrigger</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Cheque_Lectora_de_Cheques</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND(
    OR(
        TEXT(Forma_de_Pago__c) = &quot;Cheque&quot;,
        TEXT(Forma_de_Pago__c) = &quot;Cheque Diferido&quot;
    ),
    MID( Identificacion__c,1,1) = &quot;C&quot;
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Valor%2E DesmarcaCustodia</fullName>
        <actions>
            <name>Valor_DepositadoBlank</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Valor_FechaDepositadoBlank</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Valor_FechaEnCustodiaBlanK</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Reversa Cheque en Custodia</description>
        <formula>AND(ISCHANGED( En_Custodia__c ), PRIORVALUE( En_Custodia__c ) = true )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Valor%2E FechaAcreditado</fullName>
        <actions>
            <name>Valor_FechaAcreditado</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Asigna fecha del cambio de estado de un cheque</description>
        <formula>AND(ISCHANGED(  Acreditado__c  ), PRIORVALUE(  Acreditado__c  ) = false )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Valor%2E FechaDepositado</fullName>
        <actions>
            <name>Valor_FechaDepositado</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Asigna fecha del cambio de estado de un cheque</description>
        <formula>OR( AND(ISCHANGED( Depositado__c ), PRIORVALUE( Depositado__c ) = false ),
 ISCHANGED( Fecha_en_Custodia__c )
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Valor%2E FechaEnCustodia</fullName>
