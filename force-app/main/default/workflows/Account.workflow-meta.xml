    <rules>
        <fullName>Cuenta%2E Cambio</fullName>
        <actions>
            <name>Cuenta_Actualiza_Z9_Cambio</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Verifica que el registro de la cuenta sufrió cambios y actualiza los campos correpondientes para la integración. No considera los cambios realizados por el usuario de procesos batch e integracion (apodo &quot;interfaces&quot;)</description>
        <formula>AND( 
Z9_Fecha_Integracion__c &lt; LastModifiedDate, 
 NOT(  $User.Usuario_de_Integracion__c  ) 
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cuenta%2E Clave Unica</fullName>
        <actions>
            <name>Cuenta_Clave_Unica</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 AND 2</booleanFilter>
        <criteriaItems>
            <field>Account.N_CUIT__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Codigo_Postal_Envio__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>A través de este WF se carga el campo Clave Unica con la concatenación de CUIT+00+CP. (El 00 remplaza el lugar para el código de Obtentor para integración).</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cuenta%2E Estado %22Activo%22</fullName>
        <actions>
            <name>Pasa_Estado_a_Activo</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Verifica que el domicilio de facuración y la condición impositiva estén informados y en caso verdadero cambia el Estado de la cuenta al valor &quot;Activo&quot;.</description>
        <formula>AND(   NOT( ISBLANK( Calle_Facturacion__c ) ),   NOT( ISBLANK( Localidad_de_Facturacion__c   ) ),   NOT( ISBLANK( Depto_Partido_Facturacion__c  ) ),   NOT( ISBLANK( Codigo_Postal_Facturacion__c   ) ),   NOT( ISBLANK( ERPvs__Categoria_IVA__c ) ),   NOT( ISBLANK( Calle_Envio__c ) ),   NOT( ISBLANK( Localidad_Envio__c ) ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cuenta%2E Estado %22Pendiente Activo%22</fullName>
        <actions>
            <name>Actualiza_Estado_Pendiente_Activo</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Account.Estado__c</field>
            <operation>equals</operation>
            <value>SRE</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Z9_Transacciones__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <description>Se ejecuta cuando la cuenta tiene oportunidades</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cuenta%2E Estado %22Pendiente SRE%22</fullName>
        <actions>
            <name>Cambia_Estado_a_Pendiente_SRE</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Gestionar_Pendiente_SRE</name>
            <type>Task</type>
        </actions>
        <active>false</active>
        <description>Estado = Pendiente SRE cuando no está informado el domicilio de Envio</description>
        <formula>OR(    ISBLANK( Calle_Envio__c ),    ISBLANK( Localidad_Envio__c ),    ISBLANK( Codigo_Postal_Envio__c ),     ISBLANK( Depto_Partido_Envio__c ),    ISBLANK( Provincia_Envio__c )  )</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Cuenta%2E Estado %22SRE%22</fullName>
        <actions>
            <name>Estado_SRE</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Asigna el valor &quot;SRE&quot; a las cuentas que tienen informado solamente el domicilio de envío.</description>
        <formula>AND(      NOT( ISBLANK( Calle_Envio__c ) ),      NOT( ISBLANK(  Localidad_Envio__c )),      OR(         ISBLANK( Calle_Facturacion__c ), ISBLANK(  ERPvs__Categoria_IVA__c )        ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
