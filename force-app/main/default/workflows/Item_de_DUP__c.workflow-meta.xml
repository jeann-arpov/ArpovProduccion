    </fieldUpdates>
    <fieldUpdates>
        <fullName>Hectareas_Declaradas</fullName>
        <field>Hectareas_Declaradas__c</field>
        <formula>IF( Densidad_de_Siembra__c &lt;&gt; null,
	IF( OR( TEXT(Unidad_de_Medida_Declarada__c) = &apos;Hectáreas&apos;, TEXT(Unidad_de_Medida_Declarada__c) = &apos;Hectareas&apos;), Cantidad_Declarada__c,
		IF( TEXT(Unidad_de_Medida_Declarada__c) = &apos;Granel&apos;, Cantidad_Declarada__c / Densidad_de_Siembra__c,
			( VALUE(TEXT(Unidad_de_Medida_Declarada__c)) * Cantidad_Declarada__c ) / Densidad_de_Siembra__c
		)
	),
	IF( OR(TEXT(Unidad_de_Medida_Declarada__c) = &apos;Hectáreas&apos;, TEXT(Unidad_de_Medida_Declarada__c) = &apos;Hectareas&apos;), Cantidad_Declarada__c,
	0 )
)</formula>
        <name>Hectareas Declaradas</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
