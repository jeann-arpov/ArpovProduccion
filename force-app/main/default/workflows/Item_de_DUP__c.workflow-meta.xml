    <rules>
        <fullName>Ítem de DUP%2E Consumo</fullName>
        <actions>
            <name>Consumo</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Si la cantidad informada es 0 se asigna el valor Consumo al campo Estado</description>
        <formula>AND(Cantidad_Declarada__c = 0,
Transaccion__r.RecordType.Name = &quot;DUP&quot;,  NOT( ISPICKVAL(Estado__c, &quot;Cancelada por Auditoría&quot; ) ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Ítem de DUP%2E No informada</fullName>
        <actions>
            <name>No_Informada</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Controla el Estado de la DUP</description>
        <formula>ISBLANK(   Cantidad_Declarada__c   )  &amp;&amp; NOT(ISPICKVAL(Estado__c, &quot;Vencida&quot;) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Ítem de DUP%2E Precio Producto</fullName>
        <actions>
            <name>tem_de_DUP_Precio_Producto</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>igna el precio al line item de DUP de acuerdo al campo de Precio definido a nivel producto.</description>
        <formula>ISCHANGED( Producto__c ) || (OR(PRIORVALUE( Cantidad_Declarada__c ) = 0, ISBLANK(PRIORVALUE( Cantidad_Declarada__c ))) &amp;&amp; Cantidad_Declarada__c &gt; 0)  || (ISNEW() &amp;&amp; NOT(ISBLANK(Producto__c )))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
