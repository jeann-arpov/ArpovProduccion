    </fieldUpdates>
    <fieldUpdates>
        <fullName>Asigna_Tipo_de_Cambio</fullName>
        <description>Asigna el tipo de cambio  de la DUP relacionada cuando el Subestado de la Transacción relacionada es &quot;Negativa&quot;.</description>
        <field>Tipo_de_Cambio__c</field>
        <formula>Transaccion__r.Tipo_de_Cambio__c</formula>
        <name>Asigna Tipo de Cambio</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Calcula_el_total</fullName>
        <description>Realiza el cáculo y actualiza el campo</description>
        <field>Total_a_Facturar__c</field>
        <formula>IF(  Cantidad_Declarada__c  &lt;&gt; 0,
     ( ( Cantidad_de_Facturacion__c * Precio_Unitario_Producto__c ) * Tipo_de_Cambio__c ) - 
( ( ( Cantidad_de_Facturacion__c * Precio_Unitario_Producto__c ) * Tipo_de_Cambio__c ) * NULLVALUE( Descuento__c, 0 ) ) -  
( ( ( Cantidad_de_Facturacion__c * Precio_Unitario_Producto__c ) * Tipo_de_Cambio__c ) * NULLVALUE( Descuento_Producto__c, 0 ) ) ,
     0
)</formula>
        <name>Calcula el total</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Consumo</fullName>
        <description>Se asigna el valor consumo al estado del ítem de la DUP</description>
        <field>Estado__c</field>
        <literalValue>Consumo</literalValue>
        <name>Consumo</name>
        <notifyAssignee>false</notifyAssignee>
