    <rules>
        <fullName>Item_DUP%2EDeslintadora</fullName>
        <actions>
            <name>Item_de_DUP_No_facturar</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>AND(
     Cantidad_Declarada__c  &gt; 0,
     OR(
         TEXT(Transaccion__r.Lote__r.Tipo__c) = &quot;Deslintadora&quot;,
         TEXT(Transaccion__r.Lote__r.Tipo__c) = &quot;Informe&quot;
     )
)</formula>
        <triggerType>onCreateOnly</triggerType>
