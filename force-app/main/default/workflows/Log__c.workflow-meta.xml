<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <flowActions>
        <fullName>Log_Valorres_Iniciales</fullName>
        <description>Asigna los valores a las variables de producto de Origen al registro de LOG de genearación de DUPS (LOTE)</description>
        <flow>LogGeneracionDUP</flow>
        <flowInputs>
            <name>IdObjeto</name>
            <value>{!ID_Registro_Origen__c}</value>
        </flowInputs>
        <flowInputs>
            <name>Log</name>
            <value>{!this}</value>
        </flowInputs>
        <flowInputs>
            <name>Lote</name>
            <value>{!Lote__r}</value>
        </flowInputs>
        <label>Log. Valorres Iniciales</label>
        <language>es</language>
        <protected>false</protected>
    </flowActions>
    <rules>
        <fullName>Log%2E Creacion</fullName>
        <actions>
            <name>Log_Valorres_Iniciales</name>
            <type>FlowAction</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Log__c.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
