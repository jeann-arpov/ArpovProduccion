    <rules>
        <fullName>Remesa%2E Estado Enviada</fullName>
        <actions>
            <name>Remesa_Estado_Enviada</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Remesa__c.Fecha_de_envio__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>Cuando se carga la fecha de envío, se cambia el estado a &quot;Enviada&quot;.</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Remesa%2E Modo de Envio Email</fullName>
        <actions>
            <name>Remesa_Modo_de_Envio_Email</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Determina el modo de envío &quot;Correo Electrónico&quot; si el CUIT tiene cargada una Dirección de Correo electrónico.</description>
        <formula>NOT(ISBLANK(Productor__r.Direccion_de_Correo_electronico_del_CUIT__c))</formula>
        <triggerType>onCreateOnly</triggerType>
    </rules>
