    <decisions>
        <description>Verifica si el Usuario de Mensajería de la Sesión de Mensajería tiene un contacto asociado.</description>
        <name>Hay_contacto_asociado</name>
        <label>Hay contacto asociado?</label>
        <locationX>999</locationX>
        <locationY>138</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Si</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Buscar_Contacto_de_Sesion</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Tipo_de_Canal</targetReference>
            </connector>
            <label>Si</label>
        </rules>
    </decisions>
    <decisions>
        <description>Si es Whatsapp se buscan los contactos con igual nro. de celular, si es Facebook se buscan los contactos con igual mail.</description>
        <name>Tipo_de_Canal</name>
        <label>Tipo de Canal</label>
        <locationX>998</locationX>
        <locationY>326</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Whatsapp</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ChannelType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>WhatsApp</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Contactos_con_igual_celular</targetReference>
            </connector>
            <label>Whatsapp</label>
        </rules>
        <rules>
            <name>Facebook</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ChannelType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Facebook</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Contactos_con_igual_mail</targetReference>
            </connector>
            <label>Facebook</label>
        </rules>
    </decisions>
    <decisions>
        <description>Si el origen del mensaje es &quot;Inbound Initiated&quot; varTipoMensaje = Entrante.
Si el origen del mensaje es &quot;Agent Initiated&quot; varTipoMensaje = Saliente.</description>
        <name>Tipo_de_Mensaje</name>
        <label>Tipo de Mensaje</label>
        <locationX>524</locationX>
        <locationY>131</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Entrante</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>InboundInitiated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asigna_Entrante</targetReference>
            </connector>
            <label>Entrante</label>
        </rules>
        <rules>
            <name>Saliente</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AgentInitiated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asigna_Saliente</targetReference>
            </connector>
            <label>Saliente</label>
        </rules>
    </decisions>
