    <description>Al pasar la modificación de cambio de acreditación HTs quedaron líneas de compra HT sin HTs creadas.</description>
    <environments>Default</environments>
    <formulas>
        <description>Si es Futura --&gt; Fecha Vto TN con año_actual + 1  si Fecha Inicio de Compra Futura &lt;= HOY &lt;= 31/12/año_actual, o bien
                            Fecha Vto TN                                  si 01/01/año_actual &lt;= HOY &lt; Fecha Inicio de Compra Futura
Si es Disponible --&gt; HOY.</description>
        <name>forFechaFin</name>
        <dataType>Date</dataType>
        <expression>IF(TEXT({!$Record.Tipo_de_Compra__c})=&quot;Disponible&quot;, DATEVALUE({!$Record.CreatedDate}), 
     IF( (DATE(YEAR(DATEVALUE({!$Record.CreatedDate})), 01, 01) &lt;= DATEVALUE({!$Record.CreatedDate} ) ) &amp;&amp;
         ( DATEVALUE({!$Record.CreatedDate}) &lt;  {!$Record.Producto__r.Variedad2__r.Cultivo__r.Fecha_Inicio_de_Compra_Futura__c}),
           forFechaVtoTN,
           DATE(YEAR(DATEVALUE({!$Record.CreatedDate})) + 1, MONTH(forFechaVtoTN), DAY(forFechaVtoTN)))
)</expression>
    </formulas>
    <formulas>
        <name>forFechaInicio</name>
        <dataType>Date</dataType>
        <expression>DATEVALUE({!$Record.CreatedDate})</expression>
    </formulas>
    <formulas>
        <name>forFechaVtoTN</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Producto__r.Variedad2__r.Cultivo__r.Fecha_Vencimiento_de_Tonelada__c}</expression>
    </formulas>
