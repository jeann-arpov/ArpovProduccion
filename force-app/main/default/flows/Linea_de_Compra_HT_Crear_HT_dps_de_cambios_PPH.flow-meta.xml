        <locationX>473</locationX>
        <locationY>468</locationY>
        <defaultConnectorLabel>No tiene estado</defaultConnectorLabel>
        <rules>
            <name>Tiene_estado</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Compra_HT__r.Estado__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pendiente de Facturación</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Compra_HT__r.Estado__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Facturada</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Compra_HT__r.Estado__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pagada</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Linea_tiene_estado_Pagada</targetReference>
            </connector>
            <label>Tiene estado</label>
        </rules>
    </decisions>
