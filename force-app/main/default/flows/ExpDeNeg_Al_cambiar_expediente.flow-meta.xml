<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Cada vez que un expediente de negativos se modifica y la acción es Derivar a CTV / Auditoría Documental / Facturar Regalía E3, se cambia la visibilidad de los archivos existentes.
Se agrega que el estado sea Finalizado también.</description>
    <environments>Default</environments>
    <interviewLabel>ExpDeNeg - Al cambiar expediente {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ExpDeNeg - Al cambiar expediente</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Cambiar_visibilidad_de_sus_archivos_asociados</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Etapa__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Deriva a CTV</stringValue>
            </value>
        </filters>
        <filters>
            <field>Etapa__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Auditoría Documental</stringValue>
            </value>
        </filters>
        <filters>
            <field>Etapa__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Facturar Regalía E3</stringValue>
            </value>
        </filters>
        <filters>
            <field>Estado_de_la_Etapa__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Finalizado</stringValue>
            </value>
        </filters>
        <object>Expediente_de_Negativos__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Cambiar_visibilidad_de_sus_archivos_asociados</name>
        <label>Cambiar visibilidad de sus archivos asociados</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <flowName>ExpDeNeg_Cambiar_visibilidad_a_archivos_asociados</flowName>
        <inputAssignments>
            <name>recordId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <outputAssignments>
            <assignToReference>varCantidadDocumentos</assignToReference>
            <name>varCantidadDocumentos</name>
        </outputAssignments>
    </subflows>
    <variables>
        <name>varCantidadDocumentos</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
        <value>
            <numberValue>0.0</numberValue>
        </value>
    </variables>
    <variables>
        <name>varDocumentosAModificar</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>ContentDocumentLink</objectType>
    </variables>
</Flow>
