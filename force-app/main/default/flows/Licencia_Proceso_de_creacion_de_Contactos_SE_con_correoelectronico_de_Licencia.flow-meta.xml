<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Existe el Contacto dentro de la Cuenta Licenciataria con correo electronico igual al Email de la Licencia?</description>
        <name>Contacto_Existente</name>
        <label>Contacto Existente?</label>
        <locationX>248</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Creacion_Nuevo_Contacto_SE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Si</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Busca_Contacto_existente.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Contacto_identificado_como_SE</targetReference>
            </connector>
            <label>Si</label>
        </rules>
    </decisions>
    <decisions>
        <description>Verifica si el contacto encontrado ya esta marcado como Contacto SE</description>
        <name>Contacto_identificado_como_SE</name>
        <label>Contacto identificado como SE?</label>
        <locationX>50</locationX>
        <locationY>468</locationY>
        <defaultConnector>
            <targetReference>Actualizacion_Contacto_de_SE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>SI_Contacto_SE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Busca_Contacto_existente.Contacto_SE__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>SI</label>
        </rules>
    </decisions>
    <description>Proceso que a partir de Licencias Aprobadas, con Licenciatario con el campo Firmante Licencia completo y el campo Email vacio genera Contacos cone el correo electronico del campo Firmante de Licencia y los marca como Contactos de SE</description>
    <environments>Default</environments>
    <formulas>
        <name>forApellidoContacto</name>
        <dataType>String</dataType>
        <expression>IF (ISBLANK({!$Record.Firmante_Last_Name__c}), 
    LEFT({!$Record.Cuenta_Productor__r.Name},80),
    {!$Record.Firmante_Last_Name__c}
  )</expression>
    </formulas>
    <formulas>
        <name>forNombreContacto</name>
        <dataType>String</dataType>
        <expression>IF ( ISBLANK({!$Record.Firmante_First_Name__c}),
     &quot;Firmante Licencia&quot;,
     {!$Record.Firmante_First_Name__c}
  )</expression>
    </formulas>
    <interviewLabel>Licencia - Proceso de creacion de Contactos SE a partir del correo electronico de Licencia {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Licencia - Proceso de creacion de Contactos SE a partir del correo electronico de Licencia</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Crea un nuevo Contacto con el Nombre, Apellido del Firmante e Email marcandolo como Contacto de SE</description>
        <name>Creacion_Nuevo_Contacto_SE</name>
        <label>Creacion Nuevo Contacto SE</label>
        <locationX>446</locationX>
        <locationY>468</locationY>
        <inputAssignments>
            <field>AccountId</field>
            <value>
                <elementReference>$Record.Cuenta_Productor__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Contacto_SE__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Email</field>
            <value>
                <elementReference>$Record.Firmante_Licencia__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>FirstName</field>
            <value>
                <elementReference>forNombreContacto</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LastName</field>
            <value>
                <elementReference>forApellidoContacto</elementReference>
            </value>
        </inputAssignments>
        <object>Contact</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <description>Identifica si el contacto ya existe dentro de la Cuenta de la Licencia para luego marcarlo como Contacto de SE</description>
        <name>Busca_Contacto_existente</name>
        <label>Busca Contacto existente</label>
        <locationX>248</locationX>
        <locationY>252</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Contacto_Existente</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Email</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Firmante_Licencia__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Cuenta_Productor__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Contact</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Actualiza el contacto exitente como Contacto de Sembra Evolucion</description>
        <name>Actualizacion_Contacto_de_SE</name>
        <label>Actualizacion Contacto de SE</label>
        <locationX>182</locationX>
        <locationY>576</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Busca_Contacto_existente.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Email</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Firmante_Licencia__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Cuenta_Productor__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Contacto_SE__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>Contact</object>
    </recordUpdates>
    <start>
        <locationX>122</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Busca_Contacto_existente</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Firmante_Licencia__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Estado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Aprobada</stringValue>
            </value>
        </filters>
        <filters>
            <field>Cuenta_Productor__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Email__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Licencia__c</object>
        <schedule>
            <frequency>Once</frequency>
            <startDate>2024-10-24</startDate>
            <startTime>12:15:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
