    <decisions>
        <name>Asignacion_Propietario_segun_Motivo_del_Caso</name>
        <label>Asignacion Propietario segun Motivo del Caso</label>
        <locationX>1078</locationX>
        <locationY>508</locationY>
        <defaultConnector>
            <targetReference>Asignar_Caso_al_Operador_de_Gestion</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Otro Motivo</defaultConnectorLabel>
        <rules>
            <name>Motivo_Informar_Pago</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Obtener_Caso_del_Transcript.Reason</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>&quot;Informar Pago&quot;</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asignar_Caso_al_Operador_de_Cobranza</targetReference>
            </connector>
            <label>Motivo Informar Pago</label>
        </rules>
    </decisions>
    <decisions>
        <description>Si el Transcript no tiene como propietario al Usuario Automated Process se actualiza el Caso con el propietario del Transcript</description>
        <name>Evaluacion_del_Propietario_del_Transcript</name>
        <label>Evaluacion del Propietario del Transcript</label>
        <locationX>787</locationX>
        <locationY>114</locationY>
        <defaultConnector>
            <targetReference>Transcript_asociado_a_Contacto</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Propietario Automated Process</defaultConnectorLabel>
        <rules>
            <name>Propietario_NO_es_Automated_Process</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Owner:User.UserType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>&quot;AutomatedProcess&quot;</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Actualizar_Propietario_del_Caso</targetReference>
            </connector>
            <label>Propietario NO es Automated Process</label>
        </rules>
    </decisions>
    <decisions>
        <name>Transcript_asociado_a_Contacto</name>
        <label>Transcript asociado a Contacto</label>
        <locationX>796</locationX>
        <locationY>316</locationY>
        <defaultConnectorLabel>Transcript sin Cuenta asociada</defaultConnectorLabel>
        <rules>
            <name>Transcript_con_Contacto</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ContactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Obtener_Contacto_del_Transcript</targetReference>
            </connector>
            <label>Transcript con Contacto</label>
        </rules>
    </decisions>
