    <description>V1: Crea o actualizar registros MOV SE para comprobantes de venta.
V2: Se agrega la actualización de la oportunidad para FC o NC del proceso automático de facturación
V3: Se agrega condición {!$Record.ERPvs__Estado__c} = &quot;CONTABILIZADO&quot; en el trigger
V4: Se agregan campos a completar en la oportunidad
V5: Se agrega todos los flujos derivados de Oportunidades tipo NC para SE
V6: Se agrega el Tipo Movimiento Cantidad al flujo de Oportunidades tipo NC para SE
V7: Se agrega Comprobantes Manuales al flujo de Oportunidades para SE</description>
    <environments>Default</environments>
    <formulas>
        <name>nvoSaldoOportunidad</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Oportunidad__r.Saldo_a_Cobrar_Comprobante__c} - {!$Record.ERPvs__Total__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>nvoStageName</name>
        <dataType>String</dataType>
        <expression>IF({!nvoSaldoOportunidad} = 0, &apos;Pagada&apos;, &apos;Facturada&apos;)</expression>
    </formulas>
