<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>56.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Identifica las ventas CRM que no generaron HTs y tildar el crear HT = true
No se tildan las ventas con Tipo de Venta = C o TDS y campaña 2023 --&gt; se sacó esta condición</description>
    <environments>Default</environments>
    <formulas>
        <name>forYear</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Record.Campana_Agricola__r.Ano__c})</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Venta CRM - Tildar para crear las HTs -  20hs {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Venta CRM - Tildar para crear las HTs -  20hs</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Actualizar_Venta_CRM</name>
        <label>Actualizar Venta CRM</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <inputAssignments>
            <field>Crear_HT__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Actualizar_Venta_CRM</targetReference>
        </connector>
        <filterLogic>(1 OR 2 OR 3 OR 6 OR 7) AND 4 AND 5</filterLogic>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Venta</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>DPD</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>DPO</stringValue>
            </value>
        </filters>
        <filters>
            <field>Semba_Evolucion__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>HT_Id__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>C</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>TDS</stringValue>
            </value>
        </filters>
        <object>Venta__c</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2024-12-12</startDate>
            <startTime>20:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
