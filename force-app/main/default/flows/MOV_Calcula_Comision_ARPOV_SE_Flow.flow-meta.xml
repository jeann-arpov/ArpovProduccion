            <field>Comision_ArPOV__c</field>
            <value>
                <elementReference>varComisionARPOV</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Porcentaje_Comision_ArPOV__c</field>
            <value>
                <elementReference>varNuevoPorcComision</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>133</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Evaluacion_Comision</targetReference>
        </connector>
        <filterFormula>{!$Record.Tipo_de_Movimiento__c} = &quot;APSE&quot; &amp;&amp; {!$Record.Importe__c} &gt; 0 &amp;&amp; {!$Record.Tipo_de_Cambio__c} &gt;0</filterFormula>
        <object>Movimientos__c</object>
