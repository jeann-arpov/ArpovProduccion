        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Si_es_en_esta_semana</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Bucle_Facturas.Fecha_Vencimiento_Comprobante__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Today</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Bucle_Facturas.Fecha_Vencimiento_Comprobante__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>ultimos_5_dias</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Bucle_Facturas.Total_Comprobante__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Bucle_Facturas.Saldo_a_Cobrar_Comprobante__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Cambiar_Enviar_recordatorio</targetReference>
            </connector>
            <label>Si, es en esta semana</label>
        </rules>
    </decisions>
