                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetFacturas</targetReference>
            </connector>
            <label>Si, ya puede recibir recordatorios</label>
        </rules>
    </decisions>
    <description>Flow Programado de envío de recordatorio de vencimiento de facturas a los productores. La lógica para poder manejar las fechas y diferenciales que tenemos que hacer para no insistir demasiado si ya se le mandó un recordatorio se hace con recursos Formula.</description>
    <formulas>
        <name>disponibleRecordatorio</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Fecha_ultimo_recordatorio__c} + {!diasAEsperar}</expression>
    </formulas>
    <formulas>
        <name>ultimos_5_dias</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate} - 5</expression>
    </formulas>
