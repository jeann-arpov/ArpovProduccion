<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>51.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Flow utilizado para marcar la Venta Informada como registro que posee una Venta asociada antes de borrarlo. El flujo y la regla de validacion &quot;Posee_Venta_asociada&quot; controlaran el borrado de registros Ventas Informadas que tienen un Venta</description>
    <interviewLabel>Ventas Informadas - Valida que no posea Venta asociado para poder borrar el registro de Ventas Informadas {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Ventas Informadas - Valida que no posea Venta asociado para poder borrar el registro de Ventas Informadas</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Actualiza campo Venta asociada</description>
        <name>Venta_asociada</name>
        <label>Venta asociada</label>
        <locationX>294</locationX>
        <locationY>278</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Asociada_a_Venta__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>Ventas_Informadas__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Venta_asociada</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Venta__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Ventas_Informadas__c</object>
        <recordTriggerType>Delete</recordTriggerType>
        <triggerType>RecordBeforeDelete</triggerType>
    </start>
    <status>Active</status>
</Flow>
