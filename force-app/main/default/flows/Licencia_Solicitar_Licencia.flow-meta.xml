    <formulas>
        <name>forCuit</name>
        <dataType>Boolean</dataType>
        <expression>IF(LEN({!Cuit_del_Firmante}) = 11, TRUE, FALSE)</expression>
    </formulas>
    <formulas>
        <description>Si no se ingresó Comercio --&gt; es false.</description>
        <name>forIngresoComercio</name>
        <dataType>Boolean</dataType>
        <expression>NOT( ISBLANK({!Comercio.recordId}) || ISNULL({!Comercio.recordId}))</expression>
    </formulas>
    <formulas>
        <name>varHoy</name>
        <dataType>Date</dataType>
        <expression>{!$Flow.CurrentDate}</expression>
    </formulas>
    <formulas>
        <name>varNombreLicencia</name>
        <dataType>String</dataType>
        <expression>{!Obtener_Obtentor.Obtentor_Prefix__c} &amp; &quot;54&quot; &amp; RIGHT(TEXT(YEAR({!$Flow.CurrentDate})), 2) &amp; &quot;G&quot;</expression>
    </formulas>
    <formulas>
        <name>varRandom</name>
        <dataType>String</dataType>
        <expression>&quot;G&quot; + left(text((now()-datetimevalue(today()))*86400000),5)</expression>
    </formulas>
