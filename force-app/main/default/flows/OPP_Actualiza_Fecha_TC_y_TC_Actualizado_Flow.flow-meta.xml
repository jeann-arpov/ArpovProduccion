<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Asigna_registro_a_la_coleccion</name>
        <label>Asigna registro a la coleccion</label>
        <locationX>264</locationX>
        <locationY>684</locationY>
        <assignmentItems>
            <assignToReference>varOportunidadReg</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Por_cada_Oportunidad</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Por_cada_Oportunidad</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Asigna_TC_y_Fecha_TC</name>
        <label>Asigna TC y Fecha TC</label>
        <locationX>264</locationX>
        <locationY>576</locationY>
        <assignmentItems>
            <assignToReference>Por_cada_Oportunidad.Fecha_Actualizacion_TC__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fechaHoy</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Por_cada_Oportunidad.Tipo_de_Cambio_Actualizado__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Obtiene_Tipo_de_Cambio.ERPvs__Vendedor__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Asigna_registro_a_la_coleccion</targetReference>
        </connector>
    </assignments>
    <description>V1: Actualiza Fecha TC y TC Actualizado para oportunidades con StageName &quot;Facturada&quot; y que no hayan sido actualizadas por el proceso de Mulesoft</description>
    <environments>Default</environments>
    <formulas>
        <name>fechaHoy</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>OPP.Actualiza Fecha TC y TC Actualizado (Flow) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>OPP.Actualiza Fecha TC y TC Actualizado (Flow)</label>
    <loops>
        <name>Por_cada_Oportunidad</name>
        <label>Por cada Oportunidad</label>
        <locationX>176</locationX>
        <locationY>468</locationY>
        <collectionReference>varOportunidadesColeccion</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Asigna_TC_y_Fecha_TC</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Actualiza_Oportunidades</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Obtiene_Oportunidades</name>
        <label>Obtiene Oportunidades</label>
        <locationX>176</locationX>
        <locationY>360</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Por_cada_Oportunidad</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>StageName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Facturada</stringValue>
            </value>
        </filters>
        <filters>
            <field>Saldo_a_Cobrar_Comprobante__c</field>
            <operator>GreaterThan</operator>
            <value>
                <numberValue>0.0</numberValue>
            </value>
        </filters>
        <filters>
            <field>Fecha_Actualizacion_TC__c</field>
            <operator>LessThan</operator>
            <value>
                <elementReference>fechaHoy</elementReference>
            </value>
        </filters>
        <object>Opportunity</object>
        <outputReference>varOportunidadesColeccion</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Fecha_Actualizacion_TC__c</queriedFields>
        <queriedFields>Tipo_de_Cambio_Actualizado__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Obtiene_Tipo_de_Cambio</name>
        <label>Obtiene Tipo de Cambio</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Obtiene_Oportunidades</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ERPvs__Moneda__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>a2NG0000000VIDC</stringValue>
            </value>
        </filters>
        <filters>
            <field>ERPvs__Fecha__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>fechaHoy</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>ERPvs__Tipo_de_cambio__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Actualiza_Oportunidades</name>
        <label>Actualiza Oportunidades</label>
        <locationX>176</locationX>
        <locationY>876</locationY>
        <inputReference>varOportunidadReg</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Obtiene_Tipo_de_Cambio</targetReference>
        </connector>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2023-07-15</startDate>
            <startTime>08:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Draft</status>
    <variables>
        <name>varOportunidadesColeccion</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Opportunity</objectType>
    </variables>
    <variables>
        <name>varOportunidadReg</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Opportunity</objectType>
    </variables>
</Flow>
