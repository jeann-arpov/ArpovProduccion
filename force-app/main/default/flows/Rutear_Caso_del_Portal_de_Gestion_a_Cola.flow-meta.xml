    <description>Para los casos generados en alguno de los Portales:
Si el caso es de Cobranzas SRE, se rutea al Operador de Cobranzas de la cuenta correspondiente.
Si el caso es de Gestión SRE, se rutea al Operador de la cuenta correspondiente.
Si el caso es de Cobranzas SE, se rutea a la cola de Casos Cobranzas SE.
Si el caso es de Gestión SE, se rutea al Operador SE de la cuenta correspondiente.
Si el caso es interno de SE, se actualiza el nombre.
Si el caso es interno de SRE, se actualiza el nombre.</description>
    <environments>Default</environments>
    <formulas>
        <name>forNombreCasoOffline</name>
        <dataType>String</dataType>
        <expression>IF( TEXT({!$Record.Reason}) &lt;&gt; &quot;Informar Pago&quot;, &quot;CUIT: &quot; &amp; {!$Record.Account.N_CUIT__c} &amp; &quot; - &quot; &amp; TEXT({!$Record.Motivo_Portal__c}) &amp; &quot; - &quot; &amp; {!$Record.CaseNumber}, {!$Record.Subject})</expression>
    </formulas>
    <formulas>
        <name>forNombreCasoPortal</name>
        <dataType>String</dataType>
        <expression>IF( TEXT({!$Record.Reason}) &lt;&gt; &quot;Informar Pago&quot; &amp;&amp; TEXT({!$Record.Reason}) &lt;&gt; &quot;PPH&quot;, &quot;CUIT: &quot; &amp; {!$Record.Account.N_CUIT__c} &amp; &quot; - &quot; &amp; TEXT({!$Record.Reason}) &amp; &quot; - &quot; &amp; {!$Record.CaseNumber}, {!$Record.Subject})</expression>
    </formulas>
    <formulas>
        <name>forNombreCasoSE</name>
        <dataType>String</dataType>
        <expression>&quot;SE-&quot; &amp; LEFT({!$Record.Account.Name}, 20) &amp; &quot;-&quot; &amp; TEXT({!$Record.Type}) &amp; &quot;-&quot; &amp; TEXT({!$Record.Tema__c}) &amp; &quot;-&quot; &amp; {!$Record.CaseNumber}</expression>
    </formulas>
    <formulas>
        <name>forNombreCasoSRE</name>
        <dataType>String</dataType>
        <expression>&quot;SRE-&quot; &amp; LEFT({!$Record.Account.Name}, 20) &amp; &quot;-&quot; &amp; TEXT({!$Record.Temporada__c}) &amp; &quot;-&quot; &amp; TEXT({!$Record.Anio__c}) &amp; &quot;-&quot; &amp; TEXT({!$Record.Tema__c})  &amp; &quot;-&quot; &amp; {!$Record.CaseNumber}</expression>
    </formulas>
    <formulas>
        <name>forNombreCasoSREtodos</name>
        <dataType>String</dataType>
        <expression>&quot;SRE-&quot; &amp; LEFT({!$Record.Account.Name}, 20) &amp; &quot;-TODOS-&quot; &amp; TEXT({!$Record.Tema__c})  &amp; &quot;-&quot; &amp; {!$Record.CaseNumber}</expression>
    </formulas>
