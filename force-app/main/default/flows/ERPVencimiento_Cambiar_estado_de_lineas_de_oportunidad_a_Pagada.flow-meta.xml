    <decisions>
        <name>El_vencimiento_cumple_las_condiciones</name>
        <label>El vencimiento cumple las condiciones?</label>
        <locationX>336</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>No cumple</defaultConnectorLabel>
        <rules>
            <name>Si_cumple</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ERPvs__Importe_MO__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.ERPvs__Importe_MO__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Comprobante_Venta__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Comprobante_Venta__r.Oportunidad__r.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Sembrá Evolución</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Comprobante_Venta__r.ERPvs__Tipo_de_comprobante__r.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>FC</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Comprobante_Venta__r.ERPvs__Comprobante_Relacionado__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Comprobante_Venta__r.Oportunidad__r.StageName</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Cancelada por NC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Buscar_los_producto_CV_con_CV_asociado_al_vencimiento</targetReference>
            </connector>
            <label>Si, cumple</label>
        </rules>
    </decisions>
