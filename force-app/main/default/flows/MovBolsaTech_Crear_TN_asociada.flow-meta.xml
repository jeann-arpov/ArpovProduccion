    <status>Active</status>
    <subflows>
        <name>Debitar_TNs</name>
        <label>Debitar TNs</label>
        <locationX>308</locationX>
        <locationY>276</locationY>
        <flowName>MovBolsaTech_Crear_Debito_de_TNs</flowName>
        <inputAssignments>
            <name>varMovBolsaTechId</name>
