    <description>Dadas una fecha inicio y una fecha fin,  devuleve la cantidad de feriados que no sean sábados ni domingos.
Se agrega la verificación de feriado por un subflow.</description>
    <environments>Default</environments>
    <formulas>
        <description>Devuelve 1 si es Domingo, 2 si es lunes, ..., 7 si Sábado.</description>
        <name>forDiaDeLaSemanaFeriado</name>
        <dataType>Number</dataType>
        <expression>WEEKDAY({!varFeriado})</expression>
        <scale>0</scale>
    </formulas>
