<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Es_linea_de_oportunidad_SE</name>
        <label>Es línea de oportunidad SE?</label>
        <locationX>380</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>No es SE</defaultConnectorLabel>
        <rules>
            <name>Si_es_SE</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity.Sembra_Evolucion__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Actualizar_estado_de_Linea_de_Compra_HT_asociada</targetReference>
            </connector>
            <label>Si, es SE</label>
        </rules>
    </decisions>
    <decisions>
        <name>Hay_linea_de_venta_HT_asociada</name>
        <label>Hay línea de venta HT asociada?</label>
        <locationX>182</locationX>
        <locationY>575</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Si</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Linea_de_Compra_HT__r.Linea_de_Venta_HT__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Actualizar_linea_de_venta_HT_asociada_a_la_linea_de_compra_HT</targetReference>
            </connector>
            <label>Si</label>
        </rules>
    </decisions>
    <description>Cuando la línea de oportunidad cambia su estado a facturada, pagada o cancelada por NC, cambia el estado en la línea de Compra HT asociada y en la línea de Venta HT, si corresponde.</description>
    <environments>Default</environments>
    <formulas>
        <name>varCantLineasFacturadas</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Opportunity.Cantidad_de_lineas_facturadas__c} + 1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>varCantLineasPagadas</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Opportunity.Cantidad_de_lineas_pagadas__c} + 1</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>LineaOportunidad - Cambia Estado a Linea Compra HT y Linea Venta HT {!$Flow.CurrentDateTime}</interviewLabel>
    <label>LineaOportunidad - Cambia Estado a Linea Compra HT y Linea Venta HT</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Actualizar_estado_de_Linea_de_Compra_HT_asociada</name>
        <label>Actualizar estado de Línea de Compra HT asociada</label>
        <locationX>182</locationX>
        <locationY>455</locationY>
        <connector>
            <targetReference>Hay_linea_de_venta_HT_asociada</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Linea_de_Compra_HT__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Estado__c</field>
            <value>
                <elementReference>$Record.Estado__c</elementReference>
            </value>
        </inputAssignments>
        <object>Linea_de_Compra_HT__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Actualizar_linea_de_venta_HT_asociada_a_la_linea_de_compra_HT</name>
        <label>Actualizar línea de venta HT asociada a la línea de compra HT</label>
        <locationX>50</locationX>
        <locationY>695</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Linea_de_Compra_HT__r.Linea_de_Venta_HT__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Estado__c</field>
            <value>
                <elementReference>$Record.Estado__c</elementReference>
            </value>
        </inputAssignments>
        <object>Linea_de_Venta_HT__c</object>
    </recordUpdates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Es_linea_de_oportunidad_SE</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Estado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Facturada</stringValue>
            </value>
        </filters>
        <filters>
            <field>Estado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Pagada</stringValue>
            </value>
        </filters>
        <filters>
            <field>Estado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Cancelada por NC</stringValue>
            </value>
        </filters>
        <filters>
            <field>Estado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Aplicada</stringValue>
            </value>
        </filters>
        <object>OpportunityLineItem</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>varEstado</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue></stringValue>
        </value>
    </variables>
</Flow>
