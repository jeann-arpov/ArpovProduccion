    <description>Cuando se Aplica un valor a una factura se distribuye el valor por cada linea de transaccion relacionada.
26/08/2015: Agrego control de carga de TC en Aplicación.
12/05/2016: Se ajusta el problema de ImporteFlow</description>
    <formulas>
        <name>Saldo_Actualizado_Factura</name>
        <dataType>Currency</dataType>
        <expression>ROUND( {!Factura.Saldo_Actualizado__c}, 2 )</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>varImporteAplicacionFlow_I</name>
        <dataType>Currency</dataType>
        <expression>IF( 
    OR(
           TEXT( {!Factura.Divisa_Comprobante__c} ) = &quot;USD&quot;,
           TEXT( {!Factura.Divisa_Comprobante__c} ) = &quot;EUR&quot;
          ),
     {!Aplicacion.Importe__c} / {!Aplicacion.Tipo_de_Cambio__c}, 
     {!Aplicacion.Importe__c} 
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>varImporteAplicarFlow</name>
        <dataType>Currency</dataType>
        <expression>IF( 
TEXT( {!Factura.Divisa_Comprobante__c} ) = &quot;USD&quot;,
{!Aplicacion.Importe__c} / {!TipoCambio.Cotizacion__c}, {!Aplicacion.Importe__c} )</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>varMoneda</name>
        <dataType>String</dataType>
        <expression>IF( 
   TEXT( {!Factura.Divisa_Comprobante__c} ) = &quot;USD&quot;, &quot;a0FG000000XjUMZ&quot;,
   IF(
       TEXT( {!Factura.Divisa_Comprobante__c} ) = &quot;EUR&quot;, &quot;a0F0f00001qzgXu&quot;, 
        &quot;a0FG000000XjUMZ&quot;
   )
)</expression>
    </formulas>
