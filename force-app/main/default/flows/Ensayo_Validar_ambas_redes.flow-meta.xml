    <decisions>
        <description>Se verifica si hay productores con ensayos de Red de Terceros con todas las licencias aprobadas.</description>
        <name>Hay_productores_de_Red_De_Terceros_OK</name>
        <label>Hay productores de Red De Terceros OK?</label>
        <locationX>182</locationX>
        <locationY>458</locationY>
        <defaultConnectorLabel>No hay Prod de Terceros OK</defaultConnectorLabel>
        <rules>
            <name>Hay_Prod_De_Terceros_OK</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varCantidadProdDeTercerosOK</leftValueReference>
                <operator>GreaterThan</operator>
