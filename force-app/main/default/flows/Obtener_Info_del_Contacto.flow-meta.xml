    <decisions>
        <description>Es para decidir si es un Chat Transcript o una Sesión de Mensajería.</description>
        <name>Es_Chat_o_Mensaje</name>
        <label>Es Chat o Mensaje?</label>
        <locationX>551</locationX>
        <locationY>77</locationY>
        <defaultConnector>
            <targetReference>Get_Chat_Transcript_Info</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Es Chat</defaultConnectorLabel>
        <rules>
            <name>Es_Mensaje</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varChatKey</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Obtener_Info_de_Sesion_de_Mensajeria</targetReference>
            </connector>
            <label>Es Mensaje</label>
        </rules>
    </decisions>
    <decisions>
        <name>Es_un_Caso_de_Cobranzas</name>
        <label>Es un Caso de Cobranzas?</label>
        <locationX>1012</locationX>
        <locationY>375</locationY>
        <defaultConnector>
            <targetReference>Asignar_Cola_Propietario_de_Cuenta</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No es Caso de Cobranza</defaultConnectorLabel>
        <rules>
            <name>Es_Caso_de_Cobranza</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Chat_Transcript_Info.Case.Subject</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Informar Pago</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Chat_Transcript_Info.Case.Reason</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Informar Pago</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Obtener_Contacto_Transcript</targetReference>
            </connector>
            <label>Es Caso de Cobranza</label>
        </rules>
    </decisions>
    <decisions>
        <name>Existe_Operador_Logueado</name>
        <label>Existe Operador Logueado?</label>
        <locationX>577</locationX>
        <locationY>1265</locationY>
        <defaultConnector>
            <targetReference>Asignar_cola_Soporte</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Operador No Logueado</defaultConnectorLabel>
        <rules>
            <name>Operador_Logueado</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Esta_disponible_el_operador_de_la_cola_asignada</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <label>Operador Logueado</label>
        </rules>
    </decisions>
    <decisions>
        <description>Si la opción es 1 se asigna al propietario de la cuenta, si la opción es 2 o 3 se asigna al operador de cobranzas, si la opción es 4 se asigna al operador de ventas.</description>
        <name>Opci_n_de_Men_elegida</name>
        <label>Opción de Menú elegida</label>
        <locationX>571</locationX>
        <locationY>527</locationY>
        <defaultConnectorLabel>Otra Opción</defaultConnectorLabel>
        <rules>
            <name>Opci_n_1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varOpcionDeMenu</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>1</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asignar_Cola_Asociada</targetReference>
            </connector>
            <label>Opción 1</label>
        </rules>
        <rules>
            <name>Opci_n_2_o_3</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varOpcionDeMenu</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>2</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varOpcionDeMenu</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>3</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asignar_Cola_Op_Cobranza</targetReference>
            </connector>
            <label>Opción 2 o 3</label>
        </rules>
        <rules>
            <name>Opci_n_4</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varOpcionDeMenu</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>4</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asignar_Cola_Op_Venta</targetReference>
            </connector>
            <label>Opción 4</label>
        </rules>
    </decisions>
    <description>Devuelve el nombre del contacto de la Sesión de Mensajería o del Chat Transcript y la cola asociada al Propietario (u Operador de Cobranzas u Operador de Ventas) de la Cuenta del Contacto. Chequea que el operador asignado a la cola se encuentre logueado.</description>
