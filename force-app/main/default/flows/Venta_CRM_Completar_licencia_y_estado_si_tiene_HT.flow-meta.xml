    <decisions>
        <name>Categoria_del_Producto_es_Original_o_Pre_Basica</name>
        <label>Categoría del Producto es Original o Pre Básica?</label>
        <locationX>710</locationX>
        <locationY>876</locationY>
        <defaultConnector>
            <targetReference>Hectarea_Por_Venta_o_por_Devolucion</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Otra Categoría</defaultConnectorLabel>
        <rules>
            <name>Original_o_Pre_Basica_y_2022</name>
            <conditionLogic>(1 OR 3) AND 2</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Producto__r.Categoria__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Original o Fundadora</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>forYear</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>2022.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Producto__r.Categoria__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pre Básica</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Que_tipo_de_venta_es</targetReference>
            </connector>
            <label>Original o Pre Básica y &gt;= 2022</label>
        </rules>
    </decisions>
