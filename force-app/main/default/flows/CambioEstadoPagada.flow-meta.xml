        <label>¿esta 100% Cobrada?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>siEsta</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>calcularAvanceCobranza</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Obtentor__r.Umbral_Pagada__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>estado_pagada</targetReference>
            </connector>
            <label>siCumple</label>
        </rules>
        <rules>
            <name>esMenor</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>calcularAvanceCobranza</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>$Record.Obtentor__r.Umbral_Pagada__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>estado_parcialmente_pagada</targetReference>
            </connector>
            <label>esMenor</label>
        </rules>
    </decisions>
