<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Anio_es_2021_o_mayor</name>
        <label>Año es 2021 o mayor?</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Si</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>forYear</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>2021.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Crear_la_HT_asociada_a_la_venta_CRM</targetReference>
            </connector>
            <label>Si</label>
        </rules>
    </decisions>
    <description>Cada vez que se crea una venta CRM con tipo de venta = Venta / C y Variedad Sembrá Evolución, se creará un registro de Hectárea Tecnológica positiva. Si el tipo de Venta = DPD / DPO / TDS, la HT será negativa.</description>
    <environments>Default</environments>
    <formulas>
        <description>Año de la campaña agrícola de la venta.</description>
        <name>forYear</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Record.Campana_Agricola__r.Ano__c})</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Venta CRM - Crear Hectárea Tecnológica {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Venta CRM - Crear Hectárea Tecnológica</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Actualizar_Venta_CRM</name>
        <label>Actualizar Venta CRM</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>Estado_Licencia__c</field>
            <value>
                <elementReference>Crear_la_HT_asociada_a_la_venta_CRM.varEstadoLicencia</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>HT_Id__c</field>
            <value>
                <elementReference>Crear_la_HT_asociada_a_la_venta_CRM.varHTid</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Licencia__c</field>
            <value>
                <elementReference>Crear_la_HT_asociada_a_la_venta_CRM.varLicenciaId</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Anio_es_2021_o_mayor</targetReference>
        </connector>
        <filterLogic>(1 OR 2 OR 3 OR 4 OR 5) AND 6 AND 7</filterLogic>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Venta</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>DPD</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>DPO</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>C</stringValue>
            </value>
        </filters>
        <filters>
            <field>Tipo_de_Venta__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>TDS</stringValue>
            </value>
        </filters>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>a0IQk00000GKvUEMA1</stringValue>
            </value>
        </filters>
        <filters>
            <field>HT_Id__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Venta__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
    <subflows>
