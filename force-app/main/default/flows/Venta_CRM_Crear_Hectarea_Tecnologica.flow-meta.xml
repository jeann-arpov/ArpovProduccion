        <label>Crear la HT asociada a la venta CRM</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <connector>
            <targetReference>Actualizar_Venta_CRM</targetReference>
        </connector>
        <flowName>Venta_CRM_Crear_HT</flowName>
        <inputAssignments>
