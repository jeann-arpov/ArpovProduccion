<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Por única vez, se completa el expediente de Negativos en el movim Bolsa Tech para todas las TNs de origen Bolsa Tech con expediente de negativos</description>
    <environments>Default</environments>
    <interviewLabel>TN - Proceso Unico - Completar Expediente en Movim BT {!$Flow.CurrentDateTime}</interviewLabel>
    <label>TN - Proceso Unico - Completar Expediente en Movim BT</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Actualizar_el_Movim_Bolsa_Tech_Asociado</name>
        <label>Actualizar el Movim Bolsa Tech Asociado</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Mov_BolsaTech__r.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Expediente_de_Negativos__c</field>
            <value>
                <elementReference>$Record.Expediente_de_Negativos__r.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Obtentor__c</field>
            <value>
                <elementReference>$Setup.Sembra_Evolucion__c.Corteva_30_Id__c</elementReference>
            </value>
        </inputAssignments>
        <object>Movimiento_BolsaTech__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Actualizar_el_Movim_Bolsa_Tech_Asociado</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Expediente_de_Negativos__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Origen__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>BolsaTech</stringValue>
            </value>
        </filters>
        <object>Tonelada__c</object>
        <schedule>
            <frequency>Once</frequency>
            <startDate>2024-07-15</startDate>
            <startTime>13:40:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
