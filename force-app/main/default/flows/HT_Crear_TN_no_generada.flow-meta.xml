        <dataType>Date</dataType>
        <expression>{!$Record.Cultivo__r.Fecha_Vencimiento_de_Tonelada__c}</expression>
    </formulas>
    <formulas>
        <description>Si la HT tiene origen = Compra HT --&gt; será Disponible o Futura.</description>
        <name>forTipoCompra</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!$Record.Origen__c})=&quot;Compra HT&quot;, 
    TEXT({!$Record.Linea_de_Compra_HT__r.Producto__r.Tipo_de_Compra__c}), &quot;&quot;)</expression>
    </formulas>
