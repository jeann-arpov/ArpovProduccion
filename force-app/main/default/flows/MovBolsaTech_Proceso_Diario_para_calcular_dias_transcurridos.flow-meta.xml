<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Si todavía no pasaron 8 días hábiles desde la fecha de análisis --&gt; se calculan los días transcurridos entre HOY y la fecha de análisis.</description>
    <environments>Default</environments>
    <formulas>
        <name>forDiasTranscurridos</name>
        <dataType>Number</dataType>
        <expression>(5 * ( FLOOR( ( {!$Flow.CurrentDate} - DATE( 2014, 6, 23) ) / 7 ) ) + 
  MIN( 5, MOD( {!$Flow.CurrentDate} - DATE( 2014, 6, 23), 7 ) ) ) 
-
(5 * ( FLOOR( ( {!$Record.Fecha_Analisis__c} - DATE( 2014, 6, 23) ) / 7 ) ) + 
  MIN( 5, MOD( {!$Record.Fecha_Analisis__c} - DATE( 2014, 6, 23), 7 ) ) ) 
- 
{!Calcular_feriados.varCantidadFeriados}</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>MovBolsaTech - Calcular días transcurridos {!$Flow.CurrentDateTime}</interviewLabel>
    <label>MovBolsaTech - Proceso Diario para calcular días transcurridos</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Actualizar_Dias_Transcurridos</name>
        <label>Actualizar Días Transcurridos</label>
        <locationX>176</locationX>
        <locationY>360</locationY>
        <inputAssignments>
            <field>Dias_Transcurridos__c</field>
            <value>
                <elementReference>forDiasTranscurridos</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Calcular_feriados</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Procesar__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Movimiento_BolsaTech__c</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2023-06-27</startDate>
            <startTime>00:15:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <description>Entre la fecha de análisis y hoy</description>
        <name>Calcular_feriados</name>
        <label>Calcular feriados</label>
        <locationX>176</locationX>
        <locationY>252</locationY>
        <connector>
            <targetReference>Actualizar_Dias_Transcurridos</targetReference>
        </connector>
        <flowName>Calcular_cantidad_de_feriados</flowName>
        <inputAssignments>
            <name>varFechaFin</name>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>varFechaInicio</name>
            <value>
                <elementReference>$Record.Fecha_Analisis__c</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
</Flow>
