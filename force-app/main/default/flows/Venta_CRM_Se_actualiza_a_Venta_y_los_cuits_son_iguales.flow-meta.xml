                <rightValue>
                    <stringValue>Venta</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.HT_Id__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Categoria__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Original o Fundadora</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Anio_es_2021_o_mayor</targetReference>
            </connector>
            <label>Es Venta y no tiene HT</label>
        </rules>
