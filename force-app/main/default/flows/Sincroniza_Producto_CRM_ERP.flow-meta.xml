    <description>Cada vez que se crea o modifica un producto CRM, se crea o actualiza un producto ERP. Para los productos Sembrá Evolución se modifica el campo variedad con Variedad2.Name
Se agrega que se verifica si el producto es de SE por el record type, en lugar de usar el tilde Sembrá Evolución.</description>
    <environments>Default</environments>
    <formulas>
        <name>varNameSE</name>
        <dataType>String</dataType>
        <expression>{!$Record.Variedad2__r.Name} &amp; &quot;-SE&quot; &amp; &quot;-&quot; &amp; CASE({!$Record.Tipo_de_Compra__c}, &quot;Futura&quot;, &quot;Futura&quot; , &quot;Disponible&quot;)</expression>
    </formulas>
    <formulas>
        <name>varNuevoProducto</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
