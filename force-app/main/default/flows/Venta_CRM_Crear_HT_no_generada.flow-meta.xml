    <description>Cada vez que se tilda el campo Crear HT, se dispara este flow para crear la HT no generada.</description>
    <environments>Default</environments>
    <formulas>
        <description>Fecha Vencimiento de Tonelada con año de la campaña agrícola de la venta + 1. Ej. 01/03/2023 para soja.</description>
        <name>forFechaFin</name>
        <dataType>Date</dataType>
        <expression>Date({!forYear} + 1, MONTH({!forFechaVtoTN}), DAY({!forFechaVtoTN}))</expression>
    </formulas>
    <formulas>
        <description>Fecha Vencimiento de Tonelada con año de la campaña agrícola de la venta. Ej. 01/03/2022 para soja.</description>
        <name>forFechaInicio</name>
        <dataType>Date</dataType>
        <expression>Date({!forYear}, MONTH({!forFechaVtoTN}), DAY({!forFechaVtoTN}))</expression>
    </formulas>
    <formulas>
        <name>forFechaVtoTN</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Cultivo__r.Fecha_Vencimiento_de_Tonelada__c}</expression>
    </formulas>
    <formulas>
        <description>Año de la campaña agrícola de la venta</description>
        <name>forYear</name>
        <dataType>Number</dataType>
        <expression>VALUE({!$Record.Campana_Agricola__r.Ano__c})</expression>
        <scale>0</scale>
    </formulas>
