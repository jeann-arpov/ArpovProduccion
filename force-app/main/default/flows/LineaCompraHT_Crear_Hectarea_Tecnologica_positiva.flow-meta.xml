    <description>Cada vez que una línea de compra HT pasa a estado &quot;Facturable&quot;,  se crea la HT con cantidad positiva y etapa = Pendiente.</description>
    <environments>Default</environments>
    <formulas>
        <name>fechaCreacion</name>
        <dataType>String</dataType>
        <expression>TEXT(DATEVALUE({!$Record.CreatedDate}))</expression>
    </formulas>
    <formulas>
        <description>Si es Futura --&gt; Fecha Vto TN con año_actual + 1  si Fecha Inicio de Compra Futura &lt;= HOY &lt;= 31/12/año_actual, o bien
                            Fecha Vto TN                                  si 01/01/año_actual &lt;= HOY &lt; Fecha Inicio de Compra Futura
Si es Disponible --&gt; HOY.</description>
        <name>forFechaFin</name>
        <dataType>Date</dataType>
        <expression>IF(TEXT({!$Record.Tipo_de_Compra__c})=&quot;Disponible&quot;, TODAY(), 
     IF( (DATE(YEAR(TODAY()), 01, 01) &lt;= TODAY() ) &amp;&amp;
          (TODAY() &lt;  {!$Record.Producto__r.Variedad2__r.Cultivo__r.Fecha_Inicio_de_Compra_Futura__c}),
           forFechaVtoTN,
           DATE(YEAR(TODAY()) + 1, MONTH(forFechaVtoTN), DAY(forFechaVtoTN)))
)</expression>
    </formulas>
    <formulas>
        <name>forFechaInicio</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <name>forFechaVtoTN</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Producto__r.Variedad2__r.Cultivo__r.Fecha_Vencimiento_de_Tonelada__c}</expression>
    </formulas>
