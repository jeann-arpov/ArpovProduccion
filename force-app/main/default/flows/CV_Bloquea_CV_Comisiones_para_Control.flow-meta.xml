<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Evalua que el Tipo de Comprobante sea de un CV de Comisiones</description>
        <name>Es_CV_Comisiones</name>
        <label>Es CV Comisiones?</label>
        <locationX>380</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Resultado predeterminado</defaultConnectorLabel>
        <rules>
            <name>SI</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ERPvs__Tipo_de_comprobante__r.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Comisiones</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ERPvs__Contabilizar__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Evalua_Periodo_Liquidacion_Comisiones</targetReference>
            </connector>
            <label>SI</label>
        </rules>
    </decisions>
    <decisions>
        <name>Evalua_Periodo_Liquidacion_Comisiones</name>
        <label>Evalua Periodo Liquidacion Comisiones</label>
        <locationX>182</locationX>
        <locationY>395</locationY>
        <defaultConnector>
            <targetReference>Desbloquea_registro</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Resultado predeterminado</defaultConnectorLabel>
        <rules>
            <name>Vacio</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Periodo_Liquidado_Comisiones__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Bloquea_registro</targetReference>
            </connector>
            <label>Vacio</label>
        </rules>
    </decisions>
    <description>Ve: se procede a ejecutar los cambios en el registro antes de ser guardaro.</description>
    <environments>Default</environments>
    <interviewLabel>CV.Bloquea CV Comisiones para Control {!$Flow.CurrentDateTime}</interviewLabel>
    <label>CV.Bloquea CV Comisiones para Control (Flow)</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Bloquea_registro</name>
        <label>Bloquea registro</label>
        <locationX>50</locationX>
        <locationY>503</locationY>
        <inputAssignments>
            <field>ERPvs__Anulada__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Desbloquea_registro</name>
        <label>Desbloquea registro</label>
        <locationX>314</locationX>
        <locationY>503</locationY>
        <inputAssignments>
            <field>ERPvs__Anulada__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Es_CV_Comisiones</targetReference>
        </connector>
        <filterFormula>CONTAINS({!$Record.ERPvs__Tipo_de_comprobante__r.Name}, &quot;Comisiones&quot;) &amp;&amp; {!$Record.ERPvs__Contabilizar__c} = False</filterFormula>
        <object>ERPvs__Comprobante_Venta__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
