        <defaultConnector>
            <targetReference>NoHayTNs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No hay TNs</defaultConnectorLabel>
        <rules>
            <name>Hay_TNs</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Buscar_Expediente.Saldo_CG__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>-3.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Buscar_Expediente.Tipo_expendiente__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PRI</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Buscar_Expediente.Tipo_expendiente__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Actualizar_Expediente</targetReference>
            </connector>
            <label>Hay TNs</label>
        </rules>
    </decisions>
