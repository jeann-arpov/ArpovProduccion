<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>55.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>V1: Elimina registros MOV SE por DC</description>
    <environments>Default</environments>
    <interviewLabel>MF.Elimina registros MOV SE por DC (Flow) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>MF.Elimina registros MOV SE por DC (Flow)</label>
    <loops>
        <name>Recorre_los_DDA</name>
        <label>Recorre los DDA</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <collectionReference>Buscar_DDA</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Buscar_MOV</targetReference>
        </nextValueConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordDeletes>
        <name>Eliminar_MOV</name>
        <label>Eliminar MOV</label>
        <locationX>264</locationX>
        <locationY>647</locationY>
        <connector>
            <targetReference>Recorre_los_DDA</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Buscar_MOV.Id</elementReference>
            </value>
        </filters>
        <object>Movimientos__c</object>
    </recordDeletes>
    <recordLookups>
        <name>Buscar_DDA</name>
        <label>Buscar DDA</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Recorre_los_DDA</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ERPvs__Movimiento_de_Fondo__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Moneda__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>ARS</stringValue>
            </value>
        </filters>
        <filters>
            <field>ERPvs__Signo__c</field>
            <operator>EqualTo</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>ERPvs__Documento_Afectado__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Buscar_MOV</name>
        <label>Buscar MOV</label>
        <locationX>264</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Eliminar_MOV</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Documento_Afectado__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Recorre_los_DDA.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Movimientos__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Buscar_DDA</targetReference>
        </connector>
        <filterFormula>{!$Record.ERPvs__Tipo_Comprobante_Movimiento_Fondo__r.Name} = &quot;Cobranzas CYO SE DC (sin aplicar)&quot;  &amp;&amp; 
ISCHANGED({!$Record.ERPvs__Contabilizar__c}) &amp;&amp; 
{!$Record.ERPvs__Contabilizar__c} = FALSE</filterFormula>
        <object>ERPvs__Movimiento_Fondo__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
