        <defaultConnectorLabel>No, no es en esta semana</defaultConnectorLabel>
        <rules>
            <name>Si_es_en_esta_semana</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>BucleFacturas.Fecha_Vencimiento_Comprobante__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
