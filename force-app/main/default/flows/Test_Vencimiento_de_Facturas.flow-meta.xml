                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BucleFacturas.Fecha_Vencimiento_Comprobante__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
