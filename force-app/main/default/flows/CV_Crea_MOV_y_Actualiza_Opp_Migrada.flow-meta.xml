    <description>&quot;Proyecto 31/07/2024: Migración PB a Flow por discontinuación de la herramienta Salesforce
Reemplaza a PB: CV.CV.Crea MOV y Actualiza Opp y Flow: CV.Crea MOV y Actualiza Opp (Flow)&quot;
V2: Se actualiza el nodo de decisión sobre diferencia de cambio ya que la herramienta de migración PB/Flow dejó las condiciones duplicadas</description>
    <environments>Default</environments>
    <formulas>
        <name>NC_IMPORTE_APLICAR_MONEDA_COMPROBANTE</name>
        <dataType>Number</dataType>
        <expression>IF({!$Record.Codigo_Moneda__c} = {!$Record.ERPvs__Comprobante_Relacionado__r.Codigo_Moneda__c}, {!$Record.Total2__c}, {!$Record.Total2__c}/{!$Record.ERPvs__Comprobante_Relacionado__r.ERPvs__Tc__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>NC_TC</name>
        <dataType>Number</dataType>
        <expression>IF({!$Record.Codigo_Moneda__c} = {!$Record.ERPvs__Comprobante_Relacionado__r.Codigo_Moneda__c}, {!$Record.ERPvs__Tc__c}, {!$Record.ERPvs__Comprobante_Relacionado__r.ERPvs__Tc__c})</expression>
        <scale>4</scale>
    </formulas>
    <formulas>
        <name>NuevoSaldoaCobrarComprobante</name>
        <dataType>Number</dataType>
        <expression>IF({!$Record.Codigo_Moneda__c} = TEXT({!$Record.Oportunidad__r.Divisa_Comprobante__c}), {!SaldoaCobrarComprobante} + {!$Record.Total2__c}, {!SaldoaCobrarComprobante} + ({!$Record.Total2__c}/{!$Record.ERPvs__Comprobante_Relacionado__r.ERPvs__Tc__c}))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <description>Saldo a Cobrar Comprobante en moneda de origen de la Oportunidad previo a actualizar</description>
        <name>SaldoaCobrarComprobante</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Oportunidad__r.Saldo_a_Cobrar_Comprobante__c}</expression>
        <scale>2</scale>
    </formulas>
