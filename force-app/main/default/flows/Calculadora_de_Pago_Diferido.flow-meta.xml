    <formulas>
        <name>DiferenciadeCambio</name>
        <dataType>Number</dataType>
        <expression>{!ImporteActualizado} - {!TotalComprobanteARS}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>FechaFMT</name>
        <dataType>String</dataType>
        <expression>TEXT( {!Fecha_de_Emision} ) &amp; &quot;USD&quot;</expression>
    </formulas>
    <formulas>
        <name>ImporteActualizado</name>
        <dataType>Number</dataType>
        <expression>IF({!Factura.Divisa_Comprobante__c} = &quot;USD&quot;,
{!Importe_del_Comprobante} *  {!CotizacionUSD},
{!Importe_del_Comprobante}
)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>ImporteconIntereses</name>
        <dataType>Number</dataType>
        <expression>{!ImporteActualizado} * ( 1 + ( {!Meses} / 100 ) )</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Intereses</name>
        <dataType>Number</dataType>
        <expression>{!ImporteconIntereses} - {!ImporteActualizado}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Meses</name>
        <dataType>Number</dataType>
        <expression>(MONTH({!Fecha_de_Pago})+12 - MONTH({!Fecha_de_Emision}))+ (12 * (YEAR({!Fecha_de_Pago})-YEAR({!Fecha_de_Emision})-1))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>TipoCambioComprobante</name>
        <dataType>Number</dataType>
        <expression>{!Factura.Tipo_de_Cambio_del_Comprobante__c}</expression>
        <scale>4</scale>
    </formulas>
    <formulas>
        <name>TotalComprobanteARS</name>
        <dataType>Number</dataType>
        <expression>{!Factura.Total_Comprobante__c} * {!Factura.Tipo_de_Cambio_del_Comprobante__c}</expression>
        <scale>2</scale>
    </formulas>
