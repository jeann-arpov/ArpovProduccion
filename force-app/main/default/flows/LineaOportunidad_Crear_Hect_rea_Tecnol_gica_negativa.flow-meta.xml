        <label>Estado cambió a Cancelada por NC?</label>
        <locationX>545</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>No cambió</defaultConnectorLabel>
        <rules>
            <name>Si_cambio</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Estado__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelada por NC</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Estado__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Cancelada por NC</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Sembra_Evolucion__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Buscar_HT_asociada_a_la_linea_de_compra_HT</targetReference>
            </connector>
            <label>Si, cambió</label>
        </rules>
    </decisions>
