    </recordUpdates>
    <recordUpdates>
        <name>Normalizar_CUIT_destinatario</name>
        <label>Normalizar CUIT destinatario</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Buscar_cuenta_por_CUIT</targetReference>
        </connector>
        <inputAssignments>
            <field>CUIT_Destinatario__c</field>
            <value>
                <elementReference>CUIT_Destinatario_limpio</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Normalizar_CUIT_destinatario</targetReference>
        </connector>
        <filterFormula>AND(
NOT(ISBLANK({!$Record.CUIT_Destinatario__c})),
OR(ISNEW(), ISCHANGED({!$Record.CUIT_Destinatario__c}))
)</filterFormula>
