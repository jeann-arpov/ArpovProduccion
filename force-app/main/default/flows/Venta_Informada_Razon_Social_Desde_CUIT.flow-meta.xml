                <elementReference>CUIT_Destinatario_limpio</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Asignar_razon_social_y_destinatario</name>
        <label>Asignar razón social y destinatario</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Destinatario__c</field>
            <value>
                <elementReference>Buscar_cuenta_por_CUIT.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Razon_Social_Destinatario__c</field>
            <value>
