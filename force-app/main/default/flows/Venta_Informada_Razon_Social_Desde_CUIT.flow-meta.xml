        <rules>
            <name>Si_existe</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Buscar_cuenta_por_CUIT.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Asignar_razon_social_y_destinatario</targetReference>
            </connector>
            <label>Si existe</label>
        </rules>
    </decisions>
    <description>Al crear o editar CUIT Destinatario en la ficha de Venta Informada, completa Razón Social Destinatario (y Destinatario) desde la cuenta en Salesforce. ARCA pendiente.</description>
    <environments>Default</environments>
    <formulas>
        <name>CUIT_Destinatario_limpio</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(
SUBSTITUTE(
SUBSTITUTE(
SUBSTITUTE(
SUBSTITUTE({!$Record.CUIT_Destinatario__c}, &quot;-&quot;, &quot;&quot;),
&quot;.&quot;, &quot;&quot;),
&quot; &quot;, &quot;&quot;),
&quot;/&quot;, &quot;&quot;),
&quot;,&quot;, &quot;&quot;)</expression>
    </formulas>
    <interviewLabel>Venta Informada - Razón Social desde CUIT {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Venta Informada - Razón Social desde CUIT</label>
    <processMetadataValues>
        <name>BuilderType</name>
